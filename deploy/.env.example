# NaturaScreen — production deploy env. Copy to deploy/.env and fill in.
APP_DOMAIN=naturascreen.example.org
API_DOMAIN=api.naturascreen.example.org

POSTGRES_USER=naturascreen
POSTGRES_PASSWORD=change-me-to-a-strong-secret
POSTGRES_DB=naturascreen

# Comma-separated API keys that gate write/compute endpoints.
NATURASCREEN_API_KEYS=replace-with-a-long-random-key

# Adapter extras baked into the worker image. Add neoantigen (heavier) when needed:
# WORKER_EXTRAS=docking,neoantigen,response
WORKER_EXTRAS=docking,response

# Flip to 1 after provisioning the corresponding models/data on the worker volume.
MHCFLURRY_READY=0
RESPONSE_MODEL_READY=0
