# --- Postgres ---
POSTGRES_USER=naturascreen
POSTGRES_PASSWORD=naturascreen
POSTGRES_DB=naturascreen
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis (Celery broker + live frame pub/sub) ---
REDIS_URL=redis://redis:6379/0

# --- API ---
# Comma-separated list of allowed CORS origins for the browser frontend.
NATURASCREEN_CORS_ORIGINS=http://localhost:3000
# Server-side log level.
NATURASCREEN_LOG_LEVEL=INFO

# --- COCONUT ingestion (public CC0 source) ---
COCONUT_API_BASE=https://coconut.naturalproducts.net/api

# --- Frontend (Next.js) ---
# Public base URLs the browser uses to reach the API + websocket.
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_WS_BASE=ws://localhost:8000

# --- Optional scientific tooling (real adapters; absence => `unavailable`, never faked) ---
# Path to the AutoDock Vina executable inside the worker image. Leave blank to disable docking.
VINA_BINARY=vina
# Set to 1 after `make data-mhcflurry` has fetched MHCflurry models into the image.
MHCFLURRY_READY=0
# Set to 1 after `make data-response` has produced a trained response-model checkpoint.
RESPONSE_MODEL_READY=0
